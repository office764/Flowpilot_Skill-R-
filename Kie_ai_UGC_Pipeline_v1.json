        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json.data || item.json;\n  const response = data.response || {};\n  const resultUrls = response.resultUrls || [];\n  const imageUrl = resultUrls[0] || response.imageUrl || '';\n  \n  const promptData = $('프롬프트 JSON 파싱').item.json;\n  \n  results.push({\n    json: {\n      image_url: imageUrl,\n      image_task_id: data.taskId || '',\n      video_prompt: promptData.video_prompt || '',\n      brand_name: promptData.brand_name || '',\n      product_name: promptData.product_name || '',\n      row_number: promptData.row_number || ''\n    }\n  });\n}\n\nreturn results;"
      },
