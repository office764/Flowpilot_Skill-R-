        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json.data || item.json;\n  const response = data.response || {};\n  const resultUrls = response.resultUrls || [];\n  const videoUrl = resultUrls[0] || response.videoUrl || '';\n  \n  const imgData = $('이미지 URL 추출').item.json;\n  \n  results.push({\n    json: {\n      video_url: videoUrl,\n      video_task_id: data.taskId || '',\n      image_url: imgData.image_url || '',\n      brand_name: imgData.brand_name || '',\n      product_name: imgData.product_name || '',\n      row_number: imgData.row_number || '',\n      status: 'COMPLETED',\n      completed_at: new Date().toISOString()\n    }\n  });\n}\n\nreturn results;"
