        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={\n  \"prompt\": \"{{ $json.image_prompt }}\",\n  \"size\": \"3:2\",\n  \"nVariants\": 1,\n  \"isEnhance\": false,\n  \"enableFallback\": true\n}"
      },
